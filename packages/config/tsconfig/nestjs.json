{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Entrio NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2021",
    "lib": ["ES2021"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "noUncheckedIndexedAccess": false,
    "isolatedModules": false,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./"
  }
}
