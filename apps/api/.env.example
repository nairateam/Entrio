# --- Core ---
NODE_ENV=development
PORT=4000

# --- Database (PostgreSQL / Prisma) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/entrio?schema=public"

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AWS S3 (headshot storage) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=entrio-headshots

# --- Twilio (SMS notifications) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
