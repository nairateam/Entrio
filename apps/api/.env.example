# --- Core ---
NODE_ENV=development
PORT=4000

# --- Database (PostgreSQL / Prisma) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/entrio?schema=public"

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Cloudinary (headshot storage) ---
# Server-side uploads; if these are blank, headshot upload is skipped (check-in still works).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Web Push (host arrival notifications) ---
# Generate a keypair: pnpm --filter @entrio/api exec web-push generate-vapid-keys
# If blank, push is disabled (the in-app bell still works).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@entrio.dev

# --- Email (Resend — invite / set-password links) ---
# If RESEND_API_KEY is blank, emails are skipped and the invite link is logged.
RESEND_API_KEY=
EMAIL_FROM="Entrio <onboarding@resend.dev>"
# Base URL of the web app, used to build links in emails.
APP_URL=http://localhost:3000
