// Entrio VMS — Prisma schema (PRD §3 data model).
// Conventions: camelCase model fields map to snake_case columns (@map) and
// snake_case plural tables (@@map). Enum values match the string values in
// @entrio/types so API responses line up with the shared types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums (mirror packages/types/src/enums.ts) ----------------------------

enum UserRole {
  security
  host
  admin
}

enum VisitStatus {
  expected
  checked_in
  checked_out
  no_show
  denied
}

enum NotificationType {
  arrival_alert
  override_request
  override_approved
  overstay_alert
  host_response
  self_service_exception
}

enum NotificationChannel {
  push
  email
  in_app
}

enum NotificationStatus {
  sent
  delivered
  failed
}

enum OverrideStatus {
  pending
  approved
  denied
}

// --- Models ----------------------------------------------------------------

/// Anyone with a login (Security, Host, Admin, Super Admin, Supervisor).
model User {
  id           String   @id @default(cuid())
  fullName     String   @map("full_name")
  email        String   @unique
  phone        String?
  role         UserRole
  department   String?
  isActive     Boolean  @default(true) @map("is_active")
  /// argon2 hash — never exposed via the API/@entrio/types.
  passwordHash String   @map("password_hash")
  /// sha256 of a one-time set-password token (invite / reset); null once used.
  passwordTokenHash      String?   @map("password_token_hash")
  passwordTokenExpiresAt DateTime? @map("password_token_expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Back-relations
  visitsAsHost            Visit[]                  @relation("VisitHost")
  visitsCheckedIn         Visit[]                  @relation("VisitCheckedInBy")
  visitsCheckedOut        Visit[]                  @relation("VisitCheckedOutBy")
  visitsOverrideApproved  Visit[]                  @relation("VisitOverrideApprovedBy")
  visitorsBlocked         Visitor[]                @relation("VisitorBlockedBy")
  visitorsFlagged         Visitor[]                @relation("VisitorFlaggedBy")
  workingHoursUpdated     WorkingHour[]            @relation("WorkingHourUpdatedBy")
  blackoutDatesCreated    BlackoutDate[]           @relation("BlackoutCreatedBy")
  restrictionsAsHost      HostVisitorRestriction[] @relation("RestrictionHost")
  auditLogs               AuditLog[]               @relation("AuditActor")
  notificationsReceived   Notification[]           @relation("NotificationRecipient")
  overridesHosted         OverrideRequest[]        @relation("OverrideHost")
  overridesRequested      OverrideRequest[]        @relation("OverrideRequestedBy")
  overridesResolved       OverrideRequest[]        @relation("OverrideResolvedBy")
  pushSubscriptions       PushSubscription[]       @relation("PushSubscriptionUser")

  @@map("users")
}

/// A person who visits the facility, reused across multiple visits.
model Visitor {
  id          String    @id @default(cuid())
  fullName    String    @map("full_name")
  phone       String
  email       String?
  photoUrl    String?   @map("photo_url")
  isBlocked   Boolean   @default(false) @map("is_blocked")
  blockReason String?   @map("block_reason")
  blockedById String?   @map("blocked_by")
  blockedAt   DateTime? @map("blocked_at")
  isFlagged   Boolean   @default(false) @map("is_flagged")
  flaggedById String?   @map("flagged_by")
  flaggedAt   DateTime? @map("flagged_at")
  flagNote    String?   @map("flag_note")
  createdAt   DateTime  @default(now()) @map("created_at")

  blockedBy        User?                    @relation("VisitorBlockedBy", fields: [blockedById], references: [id])
  flaggedBy        User?                    @relation("VisitorFlaggedBy", fields: [flaggedById], references: [id])
  visits           Visit[]
  restrictions     HostVisitorRestriction[]
  overrideRequests OverrideRequest[]

  // Prevents accidental duplicates while allowing two different people to share a name.
  @@unique([fullName, phone])
  @@index([fullName])
  @@index([phone])
  @@index([isBlocked])
  @@map("visitors")
}

/// One visitor, one check-in event. Most-queried table in the system.
model Visit {
  id                    String      @id @default(cuid())
  /// Optional: self-service walk-ins capture details inline (below) with no Visitor row.
  visitorId             String?     @map("visitor_id")
  hostId                String      @map("host_id")
  /// Denormalized visitor details for self-service walk-ins (PRD v2 — no Visitor record).
  visitorName           String?     @map("visitor_name")
  visitorPhone          String?     @map("visitor_phone")
  visitorEmail          String?     @map("visitor_email")
  /// Captured headshot + drawn signature for this specific visit.
  photoUrl              String?     @map("photo_url")
  signatureUrl          String?     @map("signature_url")
  checkedInById         String?     @map("checked_in_by")
  checkedOutById        String?     @map("checked_out_by")
  purpose               String?
  status                VisitStatus @default(expected)
  /// Short typed entry code for pre-registered self-service check-in (PRD v2 §3.2).
  entryCode             String?     @unique @map("entry_code")
  /// Tap-to-agree consent captured at self-service check-in (PRD v2 §5.3).
  consentAcceptedAt     DateTime?   @map("consent_accepted_at")
  consentVersion        String?     @map("consent_version")
  checkInTime           DateTime?   @map("check_in_time")
  checkOutTime          DateTime?   @map("check_out_time")
  expectedTime          DateTime?   @map("expected_time")
  isOverride            Boolean     @default(false) @map("is_override")
  overrideApprovedById  String?     @map("override_approved_by")
  /// Host tapped "On My Way" after arrival (PRD §4.5).
  hostOnWay             Boolean     @default(false) @map("host_on_way")
  notes                 String?
  createdAt             DateTime    @default(now()) @map("created_at")

  visitor            Visitor?       @relation(fields: [visitorId], references: [id])
  host               User           @relation("VisitHost", fields: [hostId], references: [id])
  checkedInBy        User?          @relation("VisitCheckedInBy", fields: [checkedInById], references: [id])
  checkedOutBy       User?          @relation("VisitCheckedOutBy", fields: [checkedOutById], references: [id])
  overrideApprovedBy User?          @relation("VisitOverrideApprovedBy", fields: [overrideApprovedById], references: [id])
  notifications      Notification[]
  overrideRequest    OverrideRequest?

  @@index([status])
  @@index([checkInTime])
  @@index([hostId])
  @@index([visitorId])
  @@map("visits")
}

/// Admin-managed department pick-list. Users still store a free-text `department`
/// string; this is the canonical list that drives the department dropdowns.
model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("departments")
}

/// A shared self-service check-in device (PRD v2 §2.1). Authenticates with a
/// scoped random token (hashed at rest) — never logs in as a human user.
model Device {
  id          String    @id @default(cuid())
  label       String
  /// sha256 of the device's high-entropy API token (deterministic, for lookup);
  /// the plaintext is shown to Admin once at creation and never stored.
  apiTokenHash String   @map("api_token_hash")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastUsedAt  DateTime? @map("last_used_at")

  @@map("devices")
}

/// A browser Web Push subscription (one per user per device/browser). Used to
/// deliver host arrival alerts as push notifications (replaces the SMS channel).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("PushSubscriptionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

/// When the facility is open (one row per weekday).
model WorkingHour {
  id          String   @id @default(cuid())
  dayOfWeek   Int      @map("day_of_week")
  openTime    String   @map("open_time")
  closeTime   String   @map("close_time")
  isActive    Boolean  @default(true) @map("is_active")
  updatedById String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation("WorkingHourUpdatedBy", fields: [updatedById], references: [id])

  @@unique([dayOfWeek])
  @@map("working_hours")
}

/// Holidays/closures that override working hours.
model BlackoutDate {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  reason      String
  createdById String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy User? @relation("BlackoutCreatedBy", fields: [createdById], references: [id])

  @@map("blackout_dates")
}

/// Log of every notification sent.
model Notification {
  id          String             @id @default(cuid())
  visitId     String             @map("visit_id")
  recipientId String             @map("recipient_id")
  type        NotificationType
  channel     NotificationChannel
  status      NotificationStatus @default(sent)
  /// Free-text body for messages that carry one (e.g. a host's reply to the desk).
  message     String?
  sentAt      DateTime           @default(now()) @map("sent_at")
  /// When the recipient read it in the in-app inbox (null = unread).
  readAt      DateTime?          @map("read_at")

  visit     Visit @relation(fields: [visitId], references: [id])
  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id])

  @@index([recipientId])
  @@map("notifications")
}

/// Immutable record of every action. Never edited or deleted.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Host-specific "do not send this visitor to me" list (distinct from a block).
model HostVisitorRestriction {
  id        String   @id @default(cuid())
  hostId    String   @map("host_id")
  visitorId String   @map("visitor_id")
  /// Private, Admin-visible only.
  reason    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  host    User    @relation("RestrictionHost", fields: [hostId], references: [id])
  visitor Visitor @relation(fields: [visitorId], references: [id])

  @@unique([hostId, visitorId])
  @@index([hostId])
  @@map("host_visitor_restrictions")
}

/// A working-hours override request (PRD §4.8). Not in §3's table list, but the
/// approval flow needs to persist pending requests (no "pending" VisitStatus).
model OverrideRequest {
  id            String         @id @default(cuid())
  visitorId     String         @map("visitor_id")
  hostId        String         @map("host_id")
  requestedById String         @map("requested_by")
  reason        String
  status        OverrideStatus @default(pending)
  resolvedById  String?        @map("resolved_by")
  resolvedAt    DateTime?      @map("resolved_at")
  /// Set when an approved override is consumed by a check-in (one-time use).
  visitId       String?        @unique @map("visit_id")
  createdAt     DateTime       @default(now()) @map("created_at")

  visitor     Visitor @relation(fields: [visitorId], references: [id])
  host        User    @relation("OverrideHost", fields: [hostId], references: [id])
  requestedBy User    @relation("OverrideRequestedBy", fields: [requestedById], references: [id])
  resolvedBy  User?   @relation("OverrideResolvedBy", fields: [resolvedById], references: [id])
  visit       Visit?  @relation(fields: [visitId], references: [id])

  @@index([status])
  @@map("override_requests")
}
